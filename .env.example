# Copy to .env and fill in. .env is gitignored; this template is not.
# The pipeline degrades gracefully — each key you add lights up one more stage.

# --- AI: web grounding (AI_Response.py) ---
# Tavily gives the model fresh web context so answers reflect real, current
# events instead of stale training data. Free tier: 1000 searches/month.
# Sign up at tavily.com, get a key starting with `tvly-`.
# Without this key, the model still works but answers won't be grounded.
TAVILY_API_KEY=

# --- Text-to-speech: Fish Audio (tts.py) ---
# Without both of these, /debate returns text only (no audio, no video).
FISH_API_KEY=
REFERENCE_ID=

# --- Audio hosting: Cloudinary (cloudinary_upload.py) ---
# Sync.so fetches the TTS clip by URL, so it's hosted on Cloudinary first.
# Without all three, /debate returns audio but no video (mouth-flap fallback).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Lip-sync video: Sync.so (lipsync.py) ---
# The key hardcoded in the old branch quickstart.py files is LEAKED — rotate it.
SYNC_API_KEY=
# Base talking-head video Sync.so lip-syncs to (must be a public URL).
TRUMP_BASE_VIDEO_URL=

# --- Frontend (Next.js, must be NEXT_PUBLIC_*) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
