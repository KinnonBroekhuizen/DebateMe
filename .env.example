# Copy to .env and fill in. .env is gitignored; this template is not.
# The pipeline degrades gracefully — each key you add lights up one more stage.

# --- AI (existing) ---
# X/Twitter scraping for non-Trump handles. Trump uses a built-in prompt.
TWITTERAPI_IO_KEY=

# --- Text-to-speech: Fish Audio (tts.py, from Cooper/Bridge branch) ---
# Without both of these, /debate returns text only (no audio, no video).
FISH_API_KEY=
REFERENCE_ID=

# --- Lip-sync video: Sync.so (lipsync.py, from Bridge branch) ---
# The key hardcoded in the old branch quickstart.py files is LEAKED — rotate it.
SYNC_API_KEY=
# Base talking-head video Sync.so lip-syncs to (must be a public URL).
TRUMP_BASE_VIDEO_URL=
# Public URL of THIS backend so Sync.so can fetch the generated audio.
# Localhost is NOT reachable by Sync.so — set when deployed or tunnelled.
# Leave blank locally; mouth-flap fallback still works.
PUBLIC_BASE_URL=

# --- Frontend (Next.js, must be NEXT_PUBLIC_*) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
